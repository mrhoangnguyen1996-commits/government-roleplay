        // chạy (kể cả apiPost) MỘT CÁCH IM LẶNG — biểu hiện y hệt "bấm nút không
        // có phản ứng gì" / "hệ thống tê liệt hoàn toàn". Khối này đảm bảo LUÔN
        // LUÔN có một bản dự phòng an toàn, bất kể 2 file kia có tải được hay không.
        // =====================================================================
        if (typeof window.Toast === 'undefined') {
            console.warn('[CẢNH BÁO] Không tải được ui-toast.js — dùng bản thông báo dự phòng tối giản.');
            window.Toast = {
                success: (m) => console.log('[THÀNH CÔNG]', m),
                error: (m) => { console.error('[LỖI]', m); alert(m); },
                warning: (m) => console.warn('[CẢNH BÁO]', m),
                info: (m) => console.log('[THÔNG TIN]', m),
            };
        }
        if (typeof window.SFX === 'undefined') {
            console.warn('[CẢNH BÁO] Không tải được sound-engine.js — bỏ qua các hiệu ứng âm thanh mở rộng.');
            window.SFX = { siren(){}, radioBeep(){}, errorBuzz(){}, notifyDing(){}, rosterChime(){}, typingTick(){}, loginFanfare(){}, warrantAlarm(){} };
        }

        const socket = io();

        let state = {}; let registry = {}; let violations = {}; 
        let activeUser = null; let activeFileId = null; let onlineRoster = [];

        // TÍNH NĂNG MỚI v8.0: ĐA DẠNG HÓA CƠ QUAN & LOẠI GIẤY TỜ THEO TỪNG BAN NGÀNH
        // Mỗi cơ quan chỉ hiển thị đúng các loại thủ tục thuộc thẩm quyền của mình,
        // giúp quy trình nộp đơn chuyên nghiệp và đúng logic hành chính thực tế hơn.
        const AGENCY_DOC_TYPES = {
            'CÔNG AN': [['CĂN CƯỚC CÔNG DÂN', 'Căn Cước Công Dân Gắn Chíp'], ['SỔ HỘ KHẨU ĐIỆN TỬ', 'Sổ Hộ Khẩu Điện Tử'], ['GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ', 'Giấy Phép Sử Dụng Vũ Khí / CCHT'], ['ĐĂNG KÝ TẦN SỐ BỘ ĐÀM MÃ HÓA', 'Đăng Ký Tần Số Bộ Đàm']],
            'QUÂN ĐỘI': [['GIẤY PHÉP SỬ DỤNG CÔNG CỤ HỖ TRỢ', 'Giấy Phép Sử Dụng Vũ Khí Quân Dụng'], ['ĐĂNG KÝ TẦN SỐ BỘ ĐÀM MÃ HÓA', 'Đăng Ký Tần Số Bộ Đàm Quân Sự'], ['GIẤY CHỨNG NHẬN NGHĨA VỤ QUÂN SỰ', 'Giấy Chứng Nhận Hoàn Thành NVQS']],
            'TOÀ ÁN': [['ĐƠN KHỞI KIỆN DÂN SỰ', 'Đơn Khởi Kiện / Tố Tụng Dân Sự'], ['ĐƠN TỐ CÁO HÌNH SỰ', 'Đơn Tố Cáo Hình Sự'], ['GIẤY TRIỆU TẬP PHIÊN TOÀ', 'Yêu Cầu Cấp Giấy Triệu Tập']],
            'THANH TRA': [['ĐƠN TỐ CÁO HÀNH VI CÔNG VỤ', 'Đơn Tố Cáo Cán Bộ / Khiếu Nại Hành Chính'], ['ĐƠN KHIẾU NẠI QUY TRÌNH', 'Khiếu Nại Quy Trình Xử Lý Hồ Sơ']],
            'CHÍNH PHỦ': [['HỘ CHIẾU QUỐC TẾ', 'Hộ Chiếu Quốc Tế (Visa)'], ['GIẤY PHÉP KINH DOANH DOANH NGHIỆP', 'Giấy Phép Doanh Nghiệp Cấp Quốc Gia']],
            'Y TẾ': [['GIẤY CHỨNG NHẬN SỨC KHỎE', 'Giấy Chứng Nhận Sức Khỏe'], ['CHỨNG CHỈ HÀNH NGHỀ Y', 'Chứng Chỉ Hành Nghề Y Tế'], ['GIẤY XUẤT VIỆN', 'Giấy Xuất Viện / Nghỉ Ốm']],
            'GIÁO DỤC': [['BẰNG TỐT NGHIỆP', 'Văn Bằng Tốt Nghiệp Các Cấp'], ['CHỨNG CHỈ HÀNH NGHỀ GIẢNG DẠY', 'Chứng Chỉ Hành Nghề Giảng Dạy'], ['HỌC BẠ ĐIỆN TỬ', 'Trích Lục Học Bạ Điện Tử']],
            'TÀI CHÍNH': [['TỜ KHAI QUYẾT TOÁN THUẾ', 'Tờ Khai Quyết Toán Thuế Cá Nhân'], ['GIẤY PHÉP KINH DOANH DOANH NGHIỆP', 'Giấy Phép Đăng Ký Kinh Doanh'], ['HOÁ ĐƠN ĐIỆN TỬ', 'Đăng Ký Phát Hành Hoá Đơn Điện Tử']],
            'UBND': [['GIẤY KHAI SINH', 'Giấy Khai Sinh'], ['GIẤY CHỨNG NHẬN KẾT HÔN', 'Giấy Chứng Nhận Kết Hôn'], ['GIẤY PHÉP XÂY DỰNG', 'Giấy Phép Xây Dựng'], ['XÁC NHẬN TẠM TRÚ TẠM VẮNG', 'Xác Nhận Tạm Trú / Tạm Vắng']],
        };

        function updateDocTypeOptions() {
            const agencySel = document.getElementById('app-agency'); const docSel = document.getElementById('app-docType');
            if (!agencySel || !docSel) return;
            const list = AGENCY_DOC_TYPES[agencySel.value] || [];
            docSel.innerHTML = list.map(([val, label]) => `<option value="${val}">${label}</option>`).join('');
        }

        // TÍNH NĂNG MỚI v9.0: HUY HIỆU / LOGO GIẢ ĐỊNH CHO TỪNG CƠ QUAN
        // Dùng để in trên phôi bằng/căn cước/giấy phép cho sinh động và đáng tin hơn.
        const AGENCY_EMBLEM = {
            'CÔNG AN': { icon: 'fa-shield-halved', color: '#dc2626', label: 'CA' },
            'QUÂN ĐỘI': { icon: 'fa-star', color: '#16a34a', label: 'QĐ' },
            'TOÀ ÁN': { icon: 'fa-scale-balanced', color: '#7c3aed', label: 'TA' },
            'THANH TRA': { icon: 'fa-magnifying-glass', color: '#ea580c', label: 'TT' },
            'CHÍNH PHỦ': { icon: 'fa-landmark', color: '#f59e0b', label: 'CP' },
            'Y TẾ': { icon: 'fa-staff-snake', color: '#0891b2', label: 'YT' },
            'GIÁO DỤC': { icon: 'fa-graduation-cap', color: '#2563eb', label: 'GD' },
            'TÀI CHÍNH': { icon: 'fa-coins', color: '#ca8a04', label: 'TC' },
            'UBND': { icon: 'fa-building-columns', color: '#059669', label: 'UB' },
            'NGÂN HÀNG': { icon: 'fa-building-columns', color: '#facc15', label: 'NH' },
            'HỆ THỐNG': { icon: 'fa-server', color: '#64748b', label: 'HT' },
        };
        function emblemHtml(agency, size = 32) {
            const e = AGENCY_EMBLEM[agency] || AGENCY_EMBLEM['HỆ THỐNG'];
            return `<div class="holo-badge rounded-full flex items-center justify-center shadow-lg" style="width:${size}px;height:${size}px;"><i class="fa-solid ${e.icon}" style="color:#1a1a1a;font-size:${size*0.45}px;"></i></div>`;
        }

        // =====================================================================
        // TÍNH NĂNG MỚI v10.0: TRỰC QUAN HÓA QUY TRÌNH 6 BƯỚC XỬ LÝ HỒ SƠ
        // Chuẩn hóa quy trình hành chính đúng logic thực tế: Công dân nộp đơn ->
        // Chuyên viên tiếp nhận thẩm định -> Trình lãnh đạo phê duyệt -> Ra quyết
        // định -> Trả kết quả công dân -> Lưu kho lưu trữ. Hồ sơ bị khiếu nại sẽ
        // tách nhánh riêng thay vì đi tiếp vào lưu kho.
        // =====================================================================
        const WORKFLOW_STAGES = [
            { key: 'Đang Chờ Tiếp Nhận', label: 'Tiếp Nhận', icon: 'fa-inbox' },
            { key: 'Đã Tiếp Nhận Xử Lý', label: 'Thẩm Định', icon: 'fa-magnifying-glass' },
            { key: 'Trình Duyệt Sắc Lệnh', label: 'Trình Lãnh Đạo', icon: 'fa-file-signature' },
            { key: 'Quyết Định', label: 'Ra Quyết Định', icon: 'fa-gavel' },
            { key: 'Trả Kết Quả', label: 'Trả Kết Quả', icon: 'fa-handshake' },
            { key: 'Đã Đóng & Lưu Kho Mật', label: 'Lưu Kho', icon: 'fa-box-archive' },
        ];
        function stageIndexOf(status) {
            if (status === 'Đã Phê Duyệt' || status === 'Bị Bác Bỏ') return 3;
            const idx = WORKFLOW_STAGES.findIndex(s => s.key === status);
            return idx === -1 ? 0 : idx;
        }
        function renderComplaintTracker(app) {
            const stages = [
                { label: 'Gửi KN', icon: 'fa-paper-plane' },
                { label: 'Tiếp Nhận', icon: 'fa-inbox' },
                { label: 'Thẩm Tra', icon: 'fa-magnifying-glass' },
                { label: 'Kết Luận', icon: 'fa-gavel' },
                { label: 'Hoàn Tất', icon: 'fa-flag-checkered' },
            ];
            let idx = 0;
            if (app.complaintStatus === 'CHỜ TIẾP NHẬN' || app.complaintStatus === 'CHỜ THANH TRA') idx = 1;
            else if (app.complaintStatus === 'ĐÃ CHẤP NHẬN — XEM XÉT LẠI' || app.complaintStatus === 'ĐÃ BÁC KHIẾU NẠI') idx = 4;
            else if (app.escalationTier) idx = 2;
            return `<div class="bg-red-950/20 border border-red-800 rounded-xl p-3">
                <p class="text-[9px] font-black text-red-400 uppercase tracking-wider mb-2 text-center"><i class="fa-solid fa-triangle-exclamation"></i> Quy Trình Khiếu Nại Cấp ${app.escalationTier || 1}</p>
                <div class="flex items-center justify-between text-[8px] font-black px-1">
                    ${stages.map((s, i) => `
                        <div class="flex flex-col items-center flex-1 relative">
                            ${i > 0 ? `<div class="absolute top-3 right-1/2 w-full h-0.5 ${i <= idx ? 'bg-red-500' : 'bg-gray-800'}" style="z-index:0;"></div>` : ''}
                            <div class="w-5 h-5 rounded-full flex items-center justify-center relative z-10 ${i <= idx ? 'bg-red-600 text-white' : 'bg-gray-800 text-gray-600'}"><i class="fa-solid ${s.icon} text-[8px]"></i></div>
                            <span class="mt-1 uppercase ${i <= idx ? 'text-red-300' : 'text-gray-700'}" style="font-size:7px;">${s.label}</span>
                        </div>
                    `).join('')}
                </div>
            </div>`;
        }
        function renderStageTracker(app) {
            if (app.escalationTier && !app.complaintStatus?.includes('BÁC')) {
                return renderComplaintTracker(app);
            }
            const currentIdx = stageIndexOf(app.status);
            const isRejected = app.status === 'Bị Bác Bỏ';
            return `<div class="flex items-center justify-between text-[9px] font-black px-1">
                ${WORKFLOW_STAGES.map((s, i) => `
                    <div class="flex flex-col items-center flex-1 relative">
                        ${i > 0 ? `<div class="absolute top-3 right-1/2 w-full h-0.5 ${i <= currentIdx ? (isRejected && i === 3 ? 'bg-red-600' : 'bg-emerald-500') : 'bg-gray-800'}" style="z-index:0;"></div>` : ''}
                        <div class="w-6 h-6 rounded-full flex items-center justify-center relative z-10 ${i < currentIdx ? 'bg-emerald-600 text-white' : i === currentIdx ? (isRejected ? 'bg-red-600 text-white animate-pulse' : 'bg-amber-500 text-black animate-pulse') : 'bg-gray-800 text-gray-600'}">
                            <i class="fa-solid ${i < currentIdx ? 'fa-check' : s.icon} text-[9px]"></i>
                        </div>
                        <span class="mt-1 text-center uppercase ${i <= currentIdx ? 'text-gray-300' : 'text-gray-700'}" style="font-size:8px;">${s.label}</span>
                    </div>
                `).join('')}
            </div>`;
        }

        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playTone(freq, type, duration, vol) {
            try {
                const osc = audioCtx.createOscillator(); const gainNode = audioCtx.createGain();
                osc.type = type; osc.frequency.value = freq;
                gainNode.gain.setValueAtTime(vol, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + duration);
                osc.connect(gainNode); gainNode.connect(audioCtx.destination);
                osc.start(); osc.stop(audioCtx.currentTime + duration);
            } catch(e) {}
        }

        const soundClick = () => playTone(650, 'sine', 0.06, 0.08);
        const soundSuccess = () => { playTone(523.25, 'sine', 0.1, 0.12); setTimeout(() => playTone(659.25, 'sine', 0.12, 0.12), 60); };
        const soundAlert = () => { playTone(987.77, 'sawtooth', 0.18, 0.08); setTimeout(() => playTone(987.77, 'sawtooth', 0.18, 0.08), 180); };
        const soundStamp = () => { playTone(115, 'triangle', 0.22, 0.45); playTone(230, 'sawtooth', 0.06, 0.12); };

        document.addEventListener('click', (e) => {
            if(e.target.closest('button') || e.target.closest('nav b') || e.target.closest('select')) { soundClick(); }
        });

        // =====================================================================
        // HÀM GỌI API TRUNG TÂM v7.0 — TỰ ĐỘNG ĐÍNH KÈM CHỨNG THƯ CÁN BỘ,
        // KIỂM TRA LỖI HTTP, HIỂN THỊ TOAST RÕ RÀNG THAY VÌ IM LẶNG THẤT BẠI.
        // Đây là bản vá trực tiếp cho lỗi "bấm nút không thấy gì xảy ra".
        // =====================================================================
        // Các route chỉ đọc dữ liệu (không làm thay đổi trạng thái) -> không cần kéo lại state
        const READONLY_ENDPOINTS = ['/api/bot/chat'];

        async function apiPost(url, body = {}, opts = {}) {
            const payload = { ...body };
            if (activeUser && payload.actorUsername === undefined) {
                payload.actorUsername = activeUser.username;
                payload.actorPassword = activeUser.password;
            }
            try {
                const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                let data = {};
                try { data = await res.json(); } catch (e) { /* phản hồi rỗng */ }
                if (!res.ok) {
                    if (typeof SFX !== 'undefined') SFX.errorBuzz();
                    Toast.error(data.error || `Thao tác thất bại (mã lỗi ${res.status}).`);
                    return null;
                }
                if (!opts.silent && data.success && opts.successMsg) Toast.success(opts.successMsg);
                // v11.0: Đồng bộ trạng thái đầy đủ vẫn được CHỜ (await) để đảm bảo đúng
                // đắn tuyệt đối (đây là bản vá cho lỗi nghiêm trọng "bấm nút không phản
                // hồi"). Chỉ bỏ qua bước này cho các hành động nhẹ, không ảnh hưởng tới
                // hiển thị dữ liệu quan trọng (như gửi tin nhắn chat) để tăng tốc độ.
                if (!READONLY_ENDPOINTS.includes(url) && !opts.skipSync) { await forceSyncState(); }
                return data;
            } catch (netErr) {
                if (typeof SFX !== 'undefined') SFX.errorBuzz();
                Toast.error('Mất kết nối tới máy chủ. Vui lòng kiểm tra mạng và thử lại.');
                return null;
            }
        }

        // Kéo trạng thái mới nhất trực tiếp qua HTTP (độc lập hoàn toàn với WebSocket)
        async function forceSyncState() {
            try {
                const res = await fetch('/api/state');
                if (!res.ok) return;
                const data = await res.json();
                updateDataAndRender(data);
            } catch (e) { /* nếu lỗi mạng tạm thời, WebSocket vẫn có thể tự đồng bộ sau đó */ }
        }

        function startClock() { setInterval(() => { document.getElementById('clock').innerText = new Date().toLocaleTimeString('vi-VN'); }, 1000); }

        socket.on('initData', (data) => { updateDataAndRender(data); checkAndRestoreSession(); });
        socket.on('stateUpdate', (data) => { updateDataAndRender(data); });
        // TỰ ĐỘNG ĐỒNG BỘ LẠI NGAY KHI KẾT NỐI/TÁI KẾT NỐI THÀNH CÔNG (v8.0)
        // Phòng trường hợp WebSocket rớt kết nối một thời gian (máy tính ngủ, mất mạng,
        // tab bị trình duyệt tạm dừng...), khi kết nối lại, giao diện sẽ tự kéo dữ liệu
        // mới nhất thay vì hiển thị trạng thái cũ đã lỗi thời.
        socket.on('connect', () => { forceSyncState(); if (activeUser) socket.emit('identify', { username: activeUser.username }); });
        socket.on('newApplicationAlert', (appInfo) => {
            pushLiveActivity(`📨 Công dân vừa nộp hồ sơ mới [${appInfo.id}] — ${appInfo.docType} tới ${appInfo.agency}.`);
            if (activeUser && (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ' || appInfo.agency === activeUser.agency)) {
                document.getElementById('officer-alert-light').classList.remove('hidden'); soundAlert();
            }
        });
        socket.on('newChatMessage', (chatInfo) => {
            if (document.getElementById('track-id').value == chatInfo.fileId) trackApplication();
            if (activeFileId == chatInfo.fileId) renderOfficerDesk();
        });

        // TÍNH NĂNG MỚI v7.0: CẢNH BÁO KHẨN CẤP SOS THỜI GIAN THỰC TỚI MỌI THIẾT BỊ
        socket.on('sosAlert', (entry) => {
            if (typeof SFX !== 'undefined') SFX.siren(); else soundAlert();
            document.getElementById('sos-alert-light').classList.remove('hidden');
            const badge = document.getElementById('badge-sos');
            badge.innerText = (parseInt(badge.innerText || '0') + 1); badge.classList.remove('hidden');
            Toast.error(`🚨 CUỘC GỌI KHẨN CẤP TỪ ${entry.callerName} TẠI [${entry.location}]: ${entry.message}`, 8000);
            pushLiveActivity(`🚨 Cảnh báo khẩn cấp [${entry.id}] tại ${entry.location} (${entry.category || 'KHÁC'}).`);
        });

        // TÍNH NĂNG MỚI v7.0: BẢNG CÁN BỘ TRỰC BAN THỜI GIAN THỰC (ĐA NHIỆM/MULTIPLAYER)
        socket.on('rosterUpdate', (roster) => {
            const wasEmpty = onlineRoster.length === 0;
            onlineRoster = roster;
            document.getElementById('roster-count').innerText = `${roster.length} trực ban`;
            const rosterFeed = document.getElementById('roster-feed');
            if (rosterFeed) {
                rosterFeed.innerHTML = roster.length ? roster.map(o => `
                    <div class="bg-gray-950 border border-gray-800 p-2.5 rounded-xl flex items-center justify-between text-[11px]">
                        <span class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span><b class="text-white">${o.displayName}</b></span>
                        <span class="text-gray-500 font-mono">${o.role} • ${o.agency}</span>
                    </div>
                `).join('') : `<p class="text-center text-[11px] text-gray-600 py-4">Hiện chưa có cán bộ nào trực ban.</p>`;
            }
            if (!wasEmpty && typeof SFX !== 'undefined') SFX.rosterChime();
        });

        // TÍNH NĂNG MỚI v13.0: SỐ NGƯỜI TRUY CẬP TRỰC TIẾP + THÔNG BÁO CÁN BỘ MỚI VÀO TRỰC
        socket.on('visitorCount', (count) => {
            document.getElementById('visitor-count').innerText = `${count} đang online`;
        });
        socket.on('officerJoined', (info) => {
            pushLiveActivity(`👮 ${info.displayName} (${info.role} - ${info.agency}) vừa vào trực ban.`);
            if (activeUser && info.displayName !== activeUser.displayName) Toast.info(`${info.displayName} vừa vào trực ban.`);
        });

        function updateDataAndRender(data) {
            state = data.systemState; registry = data.citizenIdentityRegistry; violations = data.criminalRecordsRegistry;
            if (activeUser) activeUser = state.authorizedPersonnel[activeUser.username];
            
            if (activeUser) {
                let filtered = Object.values(state.applications).filter(a => {
                    if (activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') return true;
                    return a.agency === activeUser.agency;
                });
                const badgeCount = document.getElementById('badge-count-app');
                if (filtered.length > 0) { badgeCount.innerText = filtered.length; badgeCount.classList.remove('hidden'); } 
                else { badgeCount.classList.add('hidden'); }
            }
            renderAll();
            if (activeFileId) renderOfficerDesk();
        }

        function checkAndRestoreSession() {
            let savedSession = localStorage.getItem('sessionUser');
            if(savedSession) {
                try {
                    let creds = JSON.parse(savedSession);
                    if (state.authorizedPersonnel[creds.username] && state.authorizedPersonnel[creds.username].password === creds.password) {
                        activeUser = state.authorizedPersonnel[creds.username]; applyUserRoleLayout();
                        socket.emit('identify', { username: creds.username });
                    }
                } catch(e) { localStorage.removeItem('sessionUser'); }
            } else { renderAuth(); }
        }

        function jumpToActiveNotification() { tab('tab-officer'); document.getElementById('officer-alert-light').classList.add('hidden'); }

        function tab(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.querySelectorAll('nav button').forEach(b => { b.classList.remove('border-amber-500', 'text-amber-500'); b.classList.add('border-transparent', 'text-gray-400'); });
            const btn = document.getElementById(`btn-${id}`);
            if(btn) { btn.classList.remove('border-transparent', 'text-gray-400'); btn.classList.add('border-amber-500', 'text-amber-500'); }
            if (id === 'tab-officer') { document.getElementById('officer-alert-light').classList.add('hidden'); subtab('sub-app'); }
            if (id === 'tab-dispatch') { document.getElementById('sos-alert-light').classList.add('hidden'); document.getElementById('badge-sos').classList.add('hidden'); document.getElementById('badge-sos').innerText = '0'; }
