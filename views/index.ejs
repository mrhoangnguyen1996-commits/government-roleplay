            <div><label class="text-gray-400 block mb-1 font-bold">Mã Định Danh Cán Bộ</label><input type="text" id="log-user" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-mono focus:outline-none"></div>
            <div><label class="text-gray-400 block mb-1 font-bold">Mật Mã Hệ Thống</label><input type="password" id="log-pass" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white focus:outline-none"></div>
            <div class="flex gap-2 pt-2"><button onclick="closeLogin()" class="w-1/3 bg-gray-800 text-gray-400 py-2.5 rounded-xl uppercase font-black">Hủy</button><button onclick="login()" class="w-2/3 bg-gradient-to-r from-amber-500 to-amber-600 text-black py-2.5 rounded-xl uppercase font-black">Xác Thực</button></div>
