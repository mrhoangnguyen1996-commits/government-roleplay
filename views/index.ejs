<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CỔNG LIÊN THÔNG QUỐC GIA CHÍNH PHỦ SỐ V5.0 - ROBLOX SIMULATOR</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@400;500;600;700&display=swap');
        body { font-family: 'Space Grotesk', sans-serif; background-color: #02050e; color: #cbd5e1; }
        .font-mono-tech { font-family: 'Share Tech Mono', monospace; }
        
        /* PHÔI ẤN KÝ ĐIỆN TỬ NỔI KHỐI 3D ĐỘC QUYỀN */
        .stamp-box { position: relative; font-size: 11px; font-weight: 900; text-transform: uppercase; padding: 6px 14px; border-radius: 6px; border: 3px dashed; display: inline-block; text-align: center; letter-spacing: 1px; transform: rotate(-7deg) scale(1.05); text-shadow: 0 0 6px currentColor; background: rgba(0,0,0,0.3); box-shadow: 0 4px 10px rgba(0,0,0,0.5); animation: stampIn 0.22s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        .stamp-approved { border-color: #10b981; color: #10b981; }
        .stamp-rejected { border-color: #ef4444; color: #ef4444; }
        .stamp-pending { border-color: #f59e0b; color: #f59e0b; }
        .stamp-forwarded { border-color: #3b82f6; color: #3b82f6; }
        .stamp-leader { border-color: #c084fc; color: #c084fc; border-style: double; border-width: 5px; }
        .stamp-archived { border-color: #64748b; color: #64748b; }
        @keyframes stampIn { 0% { transform: scale(2.5) rotate(-35deg); opacity: 0; } 100% { transform: scale(1.05) rotate(-7deg); opacity: 1; } }

        /* BIỂU MẪU PHÔI VĂN BẰNG PHẢN QUANG CYBERPUNK */
        .national-card { background: radial-gradient(circle at top left, #1e293b 0%, #0f172a 70%, #020617 100%); border: 2px solid #334155; position: relative; overflow: hidden; border-radius: 16px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 20px 45px rgba(0,0,0,0.7); }
        .national-card:hover { transform: translateY(-6px) scale(1.01); border-color: #fbbf24; box-shadow: 0 0 35px rgba(251, 191, 36, 0.3); }
        .card-chip { width: 46px; height: 34px; background: linear-gradient(135deg, #fcd34d 0%, #d97706 50%, #78350f 100%); border-radius: 6px; border: 1px solid #b45309; }
        
        .marquee-container { width: 100%; overflow: hidden; white-space: nowrap; background: #060a16; border-top: 1px solid #111827; border-bottom: 1px solid #111827; }
        .marquee-content { display: inline-block; padding-left: 100%; animation: marquee 32s linear infinite; font-size: 13px; font-weight: 700; color: #f59e0b; }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }
        
        .sub-active { background: linear-gradient(90deg, #065f46 0%, #022c22 100%); border-color: #10b981; color: #fff; box-shadow: 0 0 15px rgba(16, 185, 129, 0.2); }

        /* =====================================================================
           NÂNG CẤP v8.0: HIỆU ỨNG PHÔI ĐIỆN TỬ ÁNH KIM (HOLOGRAPHIC SHINE)
           Dùng cho căn cước / bằng cấp / giấy phép để trông "sinh động" và
           đáng tin hơn — mô phỏng lớp phản quang chống giả trên giấy tờ thật.
           ===================================================================== */
        .holo-card { position: relative; overflow: hidden; isolation: isolate; }
        .holo-card::before {
            content: ''; position: absolute; inset: -60% -60%; z-index: 2; pointer-events: none;
            background: linear-gradient(115deg, transparent 30%, rgba(255,255,255,0.18) 45%, rgba(56,189,248,0.35) 50%, rgba(255,255,255,0.18) 55%, transparent 70%);
            transform: translateX(-120%) rotate(8deg); animation: holoSweep 3.2s ease-in-out infinite;
        }
        @keyframes holoSweep { 0%, 60% { transform: translateX(-120%) rotate(8deg); } 100% { transform: translateX(120%) rotate(8deg); } }
        .holo-card .holo-content { position: relative; z-index: 3; }
        .holo-badge { background: conic-gradient(from 180deg, #f59e0b, #fbbf24, #f59e0b, #d97706, #f59e0b); animation: holoBadgeSpin 4s linear infinite; }
        @keyframes holoBadgeSpin { from { filter: hue-rotate(0deg); } to { filter: hue-rotate(360deg); } }

        /* NÂNG CẤP v10.0: HIỆU ỨNG LOGO DẬP NỔI 3D TRÊN PHÔI BẰNG/CĂN CƯỚC */
        .emboss-3d { filter: drop-shadow(0 1px 0 rgba(255,255,255,0.4)) drop-shadow(0 -1px 1px rgba(0,0,0,0.6)) drop-shadow(0 3px 4px rgba(0,0,0,0.5)); transform: perspective(120px) rotateX(8deg); transition: transform 0.3s ease; }
        .emboss-3d:hover { transform: perspective(120px) rotateX(0deg) scale(1.08); }

        /* =====================================================================
           NÂNG CẤP v8.0: TỐI ƯU RESPONSIVE ĐA THIẾT BỊ
           Thanh điều hướng cuộn ngang mượt trên di động thay vì bị vỡ dòng dày đặc.
           ===================================================================== */
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        nav.nav-scroll { flex-wrap: nowrap !important; overflow-x: auto; }
        @media (max-width: 768px) {
            nav.nav-scroll button { padding: 10px 14px !important; font-size: 10px !important; white-space: nowrap; }
            header .flex.items-center.space-x-3 { gap: 6px !important; }
            .national-card { transform: none !important; }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <div>
        <!-- CỦA QUỐC GIA HEADER -->
        <header class="bg-[#050814] border-b border-gray-800 px-6 py-4 flex flex-wrap justify-between items-center shadow-2xl relative">
            <div class="flex items-center space-x-4">
                <div class="relative flex items-center justify-center">
                    <div class="absolute inset-0 bg-red-500/20 blur-xl rounded-full animate-pulse"></div>
                    <div class="bg-gradient-to-br from-red-600 via-amber-500 to-yellow-500 p-3.5 rounded-2xl text-black border border-amber-300 z-10">
                        <i class="fa-solid fa-building-columns text-2xl text-white"></i>
                    </div>
                </div>
                <div>
                    <span class="text-[10px] tracking-widest text-amber-500 uppercase font-black font-mono-tech block">HỆ THỐNG GIẢ LẬP NHẬP VAI KHÔNG CÓ THỰC ĐỜI THỰC</span>
                    <h1 class="text-2xl font-black text-white tracking-tight flex items-center gap-2">TRUNG TÂM QUỐC VỤ SỐ LIÊN THÔNG <span class="text-xs font-mono bg-red-950 text-red-400 border border-red-800 px-2 py-0.5 rounded font-black">v14.0-PRO</span></h1>
                </div>
            </div>

            <div class="flex items-center space-x-3 text-xs mt-3 lg:mt-0">
                <div id="sos-alert-light" onclick="tab('tab-dispatch')" class="hidden bg-red-600 border border-red-400 px-3 py-2 rounded-xl flex items-center gap-2 animate-pulse cursor-pointer shadow-[0_0_20px_rgba(239,68,68,0.6)]">
                    <span class="h-2 w-2 rounded-full bg-white"></span>
                    <span class="text-white font-black text-[11px] uppercase tracking-wider">🚨 CUỘC GỌI KHẨN CẤP MỚI</span>
                </div>
                <div id="officer-alert-light" onclick="jumpToActiveNotification()" class="hidden bg-red-950 border border-red-500 px-3 py-2 rounded-xl flex items-center gap-2 animate-pulse cursor-pointer">
                    <span class="h-2 w-2 rounded-full bg-red-500 shadow-[0_0_10px_#ef4444]"></span>
                    <span class="text-red-400 font-black text-[11px] uppercase tracking-wider">HỒ SƠ LIÊN PHÒNG BAN MỚI GỬI ĐẾN</span>
                </div>
                <button onclick="tab('tab-dispatch')" class="bg-red-700 hover:bg-red-800 text-white font-black px-3 py-2 rounded-xl text-[11px] uppercase tracking-wider flex items-center gap-1.5 shadow-md">
                    <i class="fa-solid fa-phone-volume"></i> Khẩn Cấp 113
                </button>
                <div id="roster-indicator" onclick="tab('tab-dispatch')" class="bg-[#0a0e1a] px-3 py-2 rounded-xl border border-gray-800 flex items-center gap-2 cursor-pointer" title="Số cán bộ đang trực ban">
                    <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span id="roster-count" class="font-black text-[11px] text-emerald-400">0 trực ban</span>
                </div>
                <div id="visitor-indicator" class="bg-[#0a0e1a] px-3 py-2 rounded-xl border border-gray-800 flex items-center gap-2" title="Tổng số người đang mở trang (công dân + cán bộ)">
                    <span class="h-2 w-2 rounded-full bg-sky-400 animate-pulse"></span>
                    <span id="visitor-count" class="font-black text-[11px] text-sky-400">0 đang online</span>
                </div>
                <div class="bg-[#0a0e1a] px-4 py-2 rounded-xl border border-gray-800 font-mono text-amber-400 font-black tracking-widest text-sm" id="clock">00:00:00</div>
                <div class="bg-[#0a0e1a] px-3 py-2 rounded-xl border border-gray-800 flex items-center gap-2">
                    <span id="security-txt" class="font-black text-[11px] tracking-wider uppercase text-emerald-400"><%= state.securityLevel %></span>
                </div>
                <div id="auth-panel"></div>
            </div>
        </header>

        <div class="marquee-container py-2 flex items-center">
            <div class="bg-red-900 text-white font-black text-[9px] px-2 py-0.5 rounded uppercase tracking-wider mx-4 z-10 animate-pulse border border-red-500">MÁY CHỦ SỐ HÓA</div>
            <div class="marquee-content" id="live-marquee"><%= state.tickerMessage %></div>
        </div>

        <!-- DI CHUYỂN TAB MATRIX CHÍNH -->
        <nav class="bg-[#050814]/95 border-b border-gray-800 px-3 md:px-6 py-1 flex gap-1 sticky top-0 z-40 backdrop-blur-md nav-scroll scrollbar-hide">
            <button onclick="tab('tab-news')" id="btn-tab-news" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-amber-500 text-amber-500 transition-all"><i class="fa-solid fa-scroll mr-1.5"></i> Trung Tâm Ấn Bản</button>
            <button onclick="tab('tab-id')" id="btn-tab-id" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-amber-400 hover:text-amber-300 transition-all"><i class="fa-solid fa-id-card mr-1.5"></i> Hồ Sơ Định Danh Công Dân</button>
            <button onclick="tab('tab-services')" id="btn-tab-services" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-purple-400 hover:text-purple-300 transition-all"><i class="fa-solid fa-file-invoice mr-1.5"></i> Nộp Đơn / Thủ Tục Trực Tuyến</button>
            <button onclick="tab('tab-dispatch')" id="btn-tab-dispatch" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-red-400 hover:text-red-300 transition-all relative"><i class="fa-solid fa-tower-broadcast mr-1.5"></i> Điều Phối Khẩn Cấp
                <span id="badge-sos" class="absolute top-1.5 right-1.5 bg-red-600 text-white text-[9px] px-1.5 py-0.5 rounded-full font-black hidden">0</span>
            </button>
            <button onclick="tab('tab-bank')" id="btn-tab-bank" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-yellow-400 hover:text-yellow-300 transition-all"><i class="fa-solid fa-building-columns mr-1.5"></i> Ngân Hàng Số</button>
            <button onclick="tab('tab-officer')" id="btn-tab-officer" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-emerald-400 hover:text-emerald-300 hidden relative">
                <i class="fa-solid fa-briefcase mr-1.5"></i> Bàn Làm Việc Bộ Ngành 
                <span id="badge-count-app" class="absolute top-1.5 right-1.5 bg-red-600 text-white text-[9px] px-1.5 py-0.5 rounded-full font-black hidden">0</span>
            </button>
            <button onclick="tab('tab-admin')" id="btn-tab-admin" class="px-5 py-3.5 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-red-400 hover:text-red-300 hidden"><i class="fa-solid fa-building-shield mr-1.5"></i> Phòng Giám Sát Tối Cao</button>
        </nav>

        <!-- MAIN GRID ĐA NHIỆM -->
        <main class="p-6 max-w-[1750px] w-full mx-auto space-y-6">
            
            <!-- TIN TỨC & AI BOT -->
            <section id="tab-news" class="grid grid-cols-1 xl:grid-cols-4 gap-6">
                <!-- TÍNH NĂNG MỚI v13.0: DẢI HOẠT ĐỘNG TRỰC TIẾP TOÀN HỆ THỐNG -->
                <div class="xl:col-span-4 bg-[#0a0f24] border border-sky-900/40 rounded-2xl px-4 py-2.5 flex items-center gap-3 overflow-hidden">
                    <span class="flex items-center gap-1.5 text-[9px] font-black text-sky-400 uppercase tracking-widest shrink-0"><span class="h-2 w-2 rounded-full bg-sky-400 animate-pulse"></span> Trực Tiếp</span>
                    <div id="live-activity-feed" style="transition: opacity 0.2s;" class="flex-1 text-[11px] text-gray-400 font-medium truncate">Đang chờ hoạt động mới...</div>
                </div>

                <!-- TÍNH NĂNG MỚI v13.0: LỐI TẮT NHANH — BỐ CỤC TRANG CHỦ HỢP LÝ HƠN -->
                <div class="xl:col-span-4 grid grid-cols-2 md:grid-cols-4 gap-3">
                    <button onclick="tab('tab-services')" class="bg-purple-950/20 hover:bg-purple-900/30 border border-purple-900/40 p-3 rounded-xl text-center transition-all"><i class="fa-solid fa-file-invoice text-purple-400 text-lg"></i><p class="text-[10px] font-black text-gray-300 mt-1">Nộp Đơn Trực Tuyến</p></button>
                    <button onclick="tab('tab-id')" class="bg-amber-950/20 hover:bg-amber-900/30 border border-amber-900/40 p-3 rounded-xl text-center transition-all"><i class="fa-solid fa-id-card text-amber-400 text-lg"></i><p class="text-[10px] font-black text-gray-300 mt-1">Tra Cứu Định Danh</p></button>
                    <button onclick="tab('tab-bank')" class="bg-yellow-950/20 hover:bg-yellow-900/30 border border-yellow-900/40 p-3 rounded-xl text-center transition-all"><i class="fa-solid fa-building-columns text-yellow-400 text-lg"></i><p class="text-[10px] font-black text-gray-300 mt-1">Ngân Hàng Số</p></button>
                    <button onclick="tab('tab-dispatch')" class="bg-red-950/20 hover:bg-red-900/30 border border-red-900/40 p-3 rounded-xl text-center transition-all"><i class="fa-solid fa-phone-volume text-red-400 text-lg"></i><p class="text-[10px] font-black text-gray-300 mt-1">Khẩn Cấp 113</p></button>
                </div>
                <div class="xl:col-span-2 space-y-4">
                    <h2 class="text-xs font-black text-gray-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-shield text-amber-500"></i> Chỉ Thị Sắc Lệnh Điều Hành Quốc Gia</h2>
                    <div id="news-feed" class="space-y-3"></div>
                </div>
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-red-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-mask text-red-500"></i> Hệ Thống Lệnh Truy Nã Toàn Quốc</h2>
                    <div id="wanted-feed" class="space-y-3"></div>
                </div>
                <!-- BOT AI TRUY XUẤT DB TỰ ĐỘNG -->
                <div class="space-y-4">
                    <h2 class="text-xs font-black text-teal-400 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-1.5"><i class="fa-solid fa-robot text-teal-400"></i> Trợ Lý Số Hóa Tuệ Đức v8 (Đồng Bộ DB Gốc)</h2>
                    <div class="bg-[#0a0f24] border border-teal-900/60 p-4 flex flex-col justify-between h-[430px] shadow-2xl rounded-2xl">
                        <div id="bot-chat-flow" class="flex-1 overflow-y-auto space-y-3 pr-1 text-xs">
                            <div class="bg-teal-950/30 border border-teal-900/50 p-3 rounded-xl text-teal-300">
                                <b class="block text-[10px] text-teal-400 uppercase mb-1"><i class="fa-solid fa-server"></i> Hệ Thống Tuệ Đức v8.0</b>
                                Chào công dân. Tôi có thể tra hồ sơ, biên bản vi phạm, lý lịch cư dân, danh sách truy nã, bảng trực tuyến, xếp hạng cán bộ và hướng dẫn mọi thủ tục hành chính. Hãy thử các gợi ý nhanh bên dưới hoặc gõ câu hỏi của bạn!
                            </div>
                        </div>
                        <div class="flex flex-wrap gap-1.5 py-2 border-t border-gray-800">
                            <button onclick="quickAsk('an ninh')" class="bg-gray-900 hover:bg-teal-900 border border-gray-800 text-teal-300 text-[9px] font-bold px-2 py-1 rounded-lg">🛡️ An ninh</button>
                            <button onclick="quickAsk('thống kê')" class="bg-gray-900 hover:bg-teal-900 border border-gray-800 text-teal-300 text-[9px] font-bold px-2 py-1 rounded-lg">📊 Thống kê</button>
                            <button onclick="quickAsk('cán bộ trực')" class="bg-gray-900 hover:bg-teal-900 border border-gray-800 text-teal-300 text-[9px] font-bold px-2 py-1 rounded-lg">🟢 Ai đang trực</button>
                            <button onclick="quickAsk('truy nã')" class="bg-gray-900 hover:bg-teal-900 border border-gray-800 text-teal-300 text-[9px] font-bold px-2 py-1 rounded-lg">🎯 Truy nã</button>
                            <button onclick="quickAsk('giúp')" class="bg-gray-900 hover:bg-teal-900 border border-gray-800 text-teal-300 text-[9px] font-bold px-2 py-1 rounded-lg">❓ Trợ giúp</button>
                        </div>
                        <div class="pt-2 border-t border-gray-800 flex gap-2">
                            <input type="text" id="bot-input" onkeydown="if(event.key==='Enter'){askAiBot();}" placeholder="Hỏi mã hồ sơ, lý lịch cư dân hoặc quy trình..." class="flex-1 bg-gray-950 border border-gray-800 p-2.5 text-xs text-white rounded-xl focus:outline-none focus:border-teal-500 font-medium">
                            <button onclick="askAiBot()" class="bg-teal-600 hover:bg-teal-700 text-white font-black px-4 text-xs rounded-xl uppercase tracking-wider transition-all">Quét</button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- TRÌNH TRA CỨU ĐỊNH DANH ĐƯỢC THIẾT KẾ LẠI CAO CẤP -->
            <!-- TÍNH NĂNG MỚI v11.0: GỘP TRA CỨU ĐỊNH DANH + KẾT XUẤT PHÔI THÀNH 1 TAB DUY NHẤT -->
            <section id="tab-id" class="hidden max-w-6xl mx-auto space-y-6">
                <div class="bg-[#0a0f24] border border-gray-800 p-6 shadow-2xl max-w-2xl mx-auto rounded-2xl">
                    <h2 class="text-xs font-black text-center text-white uppercase tracking-widest mb-4 flex items-center justify-center gap-2"><i class="fa-solid fa-id-card text-amber-500"></i> Hồ Sơ Định Danh, Văn Bằng & Tư Pháp Toàn Diện</h2>
                    <div class="flex gap-2">
                        <input type="text" id="id-search" onkeydown="if(event.key==='Enter'){searchCitizen();}" placeholder="Nhập tên tài khoản cư dân (Ví dụ: Nguyen_Manh_Hoang)..." class="flex-1 bg-gray-950 border border-gray-700 px-4 py-2.5 text-sm rounded-xl text-white font-mono focus:outline-none focus:border-amber-500">
                        <button onclick="searchCitizen()" class="bg-gradient-to-r from-amber-500 to-amber-600 text-black px-6 text-xs font-black uppercase rounded-xl tracking-widest transition-all shadow-md">Truy Quét Toàn Bộ</button>
                    </div>
                    <p class="text-[9px] text-gray-600 mt-2 text-center">Kết quả sẽ hiển thị đầy đủ: căn cước điện tử, mọi văn bằng/giấy phép, và toàn bộ biên bản vi phạm trong 1 lần tra cứu.</p>
                </div>
                <div id="id-result" class="max-w-2xl mx-auto"></div>
                <div class="space-y-4">
                    <div id="cards-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6 justify-center items-center"></div>
                </div>
                <div class="space-y-4">
                    <h3 id="violation-zone-title" class="hidden text-xs font-black uppercase text-red-400 tracking-widest flex items-center gap-2"><i class="fa-solid fa-scale-balanced text-red-500"></i> Biên Bản Vi Phạm Kịch Bản Ghi Nhận</h3>
                    <div id="violation-render-zone" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
                </div>
            </section>

            <!-- CỔNG NỘP ĐƠN TRỰC TUYẾN ĐA CƠ QUAN -->
            <section id="tab-services" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-[#0a0f24] border border-gray-800 p-5 space-y-4 shadow-xl rounded-2xl">
                    <h3 class="text-xs font-black text-gray-300 uppercase tracking-widest border-b border-gray-800 pb-2 flex items-center gap-2"><i class="fa-solid fa-file-import text-purple-400"></i> Khởi Tạo Hồ Sơ Trực Tuyến Thủ Tục Công</h3>
                    <form onsubmit="submitForm(event)" class="space-y-4 text-xs">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Tên Tài Khoản Hệ Thống (Họ_Tên)</label>
                                <input type="text" id="app-sender" required placeholder="Nguyen_Manh_Hoang" class="w-full bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-white font-mono focus:outline-none">
                            </div>
                            <div>
                                <label class="block text-gray-400 font-bold mb-1 uppercase tracking-wider">Loại Giấy Tờ / Thủ Tục</label>
