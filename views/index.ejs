        async function submitForm(e) {
            e.preventDefault();
            const sender = document.getElementById('app-sender').value.trim(); const docType = document.getElementById('app-docType').value; const priority = document.getElementById('app-priority').value; const agency = document.getElementById('app-agency').value; const content = document.getElementById('app-content').value.trim();
            const data = await apiPost('/api/applications/submit', { sender, agency, docType, content, priority });
            if (data) {
                document.getElementById('app-content').value = ''; document.getElementById('track-id').value = data.id;
                soundSuccess(); Toast.success(`Đã nộp đơn thành công! Mã hồ sơ của bạn: ${data.id}`); trackApplication();
            }
        }

        // TÍNH NĂNG MỚI v10.0: STEPPER TRỰC QUAN HÓA QUY TRÌNH XỬ LÝ HỒ SƠ
        // Giúp công dân lẫn cán bộ nhìn thấy rõ hồ sơ đang ở giai đoạn nào trong
        // toàn bộ chuỗi quy trình hành chính, tăng tính chuyên nghiệp & minh bạch.
        function renderProcessStepper(app) {
            const steps = [
                { key: 'submit', label: 'Tiếp Nhận', icon: 'fa-inbox' },
                { key: 'review', label: 'Thẩm Định', icon: 'fa-magnifying-glass' },
                { key: 'approve', label: 'Phê Duyệt', icon: 'fa-gavel' },
                { key: 'done', label: 'Trả Kết Quả', icon: 'fa-flag-checkered' },
            ];
            let activeIdx = 0;
            if (app.status === 'Đang Chờ Tiếp Nhận') activeIdx = 0;
            else if (app.status === 'Đã Tiếp Nhận Xử Lý') activeIdx = 1;
            else if (app.status === 'Trình Duyệt Sắc Lệnh') activeIdx = 2;
            else if (app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ' || app.status === 'Đã Đóng & Lưu Kho Mật') activeIdx = 3;
            else if (app.status && app.status.includes('Khiếu Nại')) activeIdx = 2; // quay lại giai đoạn thẩm định do bị khiếu nại

            const isComplaint = app.status && app.status.includes('Khiếu Nại');
            return `
                <div class="flex items-center justify-between px-1 py-2">
                    ${steps.map((s, i) => `
                        <div class="flex-1 flex flex-col items-center relative">
                            ${i > 0 ? `<div class="absolute top-3 right-1/2 w-full h-0.5 ${i <= activeIdx ? (isComplaint ? 'bg-red-600' : 'bg-emerald-600') : 'bg-gray-800'}" style="z-index:0;"></div>` : ''}
                            <div class="w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-black relative z-10 ${i < activeIdx ? (isComplaint ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white') : i === activeIdx ? (isComplaint ? 'bg-red-500 text-white animate-pulse' : 'bg-amber-500 text-black animate-pulse') : 'bg-gray-800 text-gray-600'}">
                                <i class="fa-solid ${s.icon}"></i>
                            </div>
                            <span class="text-[8px] font-bold mt-1 text-center ${i <= activeIdx ? 'text-gray-300' : 'text-gray-700'}">${s.label}</span>
                        </div>
                    `).join('')}
                </div>
                ${isComplaint ? `<p class="text-center text-[9px] text-red-400 font-black uppercase mt-1">⚠️ Hồ sơ đang trong quy trình khiếu nại — ${app.status}</p>` : ''}
            `;
        }

        function trackApplication() {
            const id = document.getElementById('track-id').value.trim(); const area = document.getElementById('track-details'); const empty = document.getElementById('track-empty');
            if (!state.applications) return; // state chưa kịp đồng bộ lần đầu, bỏ qua an toàn
            let app = state.applications[id] || state.archivedApplications[id];
            if (!app) { area.classList.add('hidden'); empty.classList.remove('hidden'); return; }
            empty.classList.add('hidden'); area.classList.remove('hidden');

            let chatHtml = '';
            app.logs.forEach(l => {
                chatHtml += `<div class="bg-gray-950 p-2.5 rounded border border-gray-900 text-[11px]"><p class="text-[9px] font-bold text-gray-500">${l.sender} • ${l.time}</p><p class="text-white mt-0.5 font-medium">${l.msg}</p></div>`;
            });
            let satBlock = '';
            if ((app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && !app.satisfaction) {
                satBlock = `
                    <div class="space-y-1.5 p-2 bg-gray-950 border border-gray-800 rounded-xl flex gap-2 justify-center">
                        <button onclick="sendAction('${id}', 'satisfaction', 'HÀI LÒNG')" class="bg-emerald-600 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase">Hài Lòng 👍</button>
                        <button onclick="sendAction('${id}', 'satisfaction', 'KHÔNG HÀI LÒNG')" class="bg-gray-700 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase">Không Hài Lòng 👎</button>
                    </div>
                `;
            } else if (app.satisfaction === 'KHÔNG HÀI LÒNG' && (app.status === 'Đã Phê Duyệt' || app.status === 'Bị Bác Bỏ') && (!app.escalationTier || app.escalationTier === 0)) {
                satBlock = `
                    <div class="space-y-2 p-3 bg-red-950/20 border border-red-900/50 rounded-xl text-center">
                        <p class="text-[10px] text-red-400 font-bold">Bạn chưa hài lòng với kết quả này. Bạn có thể khiếu nại chính thức lên Lãnh Đạo trực tiếp của cơ quan thụ lý.</p>
                        <button onclick="escalateComplaint('${id}', 1)" class="bg-orange-600 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase animate-pulse">⚠️ Khiếu Nại Cấp 1 (Lãnh Đạo)</button>
                    </div>
                `;
            } else if (app.satisfaction === 'KHÔNG HÀI LÒNG' && app.complaintStatus === 'ĐÃ BÁC KHIẾU NẠI' && app.escalationTier === 1) {
                satBlock = `
                    <div class="space-y-2 p-3 bg-red-950/30 border border-red-800 rounded-xl text-center">
                        <p class="text-[10px] text-red-400 font-bold">Khiếu nại Cấp 1 đã bị bác. Nếu vẫn chưa hài lòng, bạn có thể leo thang lên Thanh Tra Chính Phủ giám sát độc lập.</p>
                        <button onclick="escalateComplaint('${id}', 2)" class="bg-red-700 text-white font-black px-4 py-1.5 rounded-lg text-[10px] uppercase animate-pulse">🚨 KHIẾU NẠI CẤP 2 (THANH TRA)</button>
                    </div>
                `;
            } else if (app.escalationTier && app.status && app.status.includes('Khiếu Nại')) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-red-400 bg-red-950/20 p-2 rounded-xl border border-red-900/40">Hồ sơ đang xử lý khiếu nại Cấp ${app.escalationTier} — ${app.status}</div>`;
            } else if (app.satisfaction) {
                satBlock = `<div class="text-center text-[10px] font-black uppercase text-amber-500 bg-gray-950 p-2 rounded-xl border border-gray-800">Cư dân đánh giá chất lượng phục vụ: [${app.satisfaction}]${app.escalationTier ? ` • Đang khiếu nại Cấp ${app.escalationTier}` : ''}</div>`;
            }

            area.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[300px] pr-1">
                    <div class="bg-gray-950 p-3 rounded-xl border border-gray-100/10 flex justify-between items-center shadow-md">
                        <div><p class="font-black text-amber-500">${app.id} [${app.docType}]</p><span class="text-[9px] font-mono text-gray-500 block">Mức độ ưu tiên: ${app.priority}</span></div>
                        <div class="stamp-box ${app.stamp}">${app.status}</div>
                    </div>
                    <div class="bg-gray-950 p-3 rounded-xl border border-gray-900">${renderStageTracker(app)}</div>
                    <div class="space-y-2" id="citizen-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-gray-800 space-y-2">
                    ${satBlock}
                    <div class="flex gap-2">
                        <input type="text" id="citizen-chat-msg" placeholder="Nhập văn bản đàm thoại..." class="flex-1 bg-gray-950 border border-gray-800 p-2 text-xs text-white rounded-xl focus:outline-none">
                        <button onclick="citizenChat('${app.id}')" class="bg-amber-500 font-black text-black px-4 text-xs rounded-xl uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('citizen-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }

        async function escalateComplaint(id, tier) {
            const data = await apiPost('/api/applications/action', { id, action: 'escalate_complaint', tier });
            if (data) {
                if (typeof SFX !== 'undefined') SFX.warrantAlarm();
                Toast.warning(tier === 1 ? 'Đã gửi khiếu nại Cấp 1 lên Lãnh Đạo trực tiếp.' : 'Đã leo thang khiếu nại Cấp 2 lên Thanh Tra Chính Phủ!');
                trackApplication();
            }
        }

        async function citizenChat(id) {
            const msg = document.getElementById('citizen-chat-msg').value.trim(); if (!msg) return;
            const data = await apiPost('/api/applications/action', { id, action: 'chat', msg, officerName: `Công Dân (@${(state.applications[id] || state.archivedApplications[id]).sender})` }, { skipSync: true });
            if (data) document.getElementById('citizen-chat-msg').value = '';
        }

        async function submitSOS(e) {
            e.preventDefault();
            const callerName = document.getElementById('sos-caller').value.trim();
            const category = document.getElementById('sos-category').value;
            const location = document.getElementById('sos-location').value.trim();
            const message = document.getElementById('sos-message').value.trim();
            if (!location || !message) { Toast.warning('Vui lòng nhập vị trí và mô tả sự việc.'); return; }
            const data = await apiPost('/api/dispatch/sos', { callerName, category, location, message });
            if (data) {
                document.getElementById('sos-location').value = ''; document.getElementById('sos-message').value = '';
                Toast.success(`Đã gửi cảnh báo khẩn cấp [${data.id}] tới toàn bộ cán bộ trực ban!`);
            }
        }

        async function resolveSOS(id) {
            const data = await apiPost('/api/dispatch/resolve', { id });
            if (data) { soundSuccess(); Toast.success('Đã cử cán bộ tiếp nhận xử lý cuộc gọi khẩn cấp.'); }
        }

        function exportSystemLogs() {
            if (!state.systemLogs || !state.systemLogs.length) { Toast.warning('Chưa có nhật ký nào để xuất.'); return; }
            const w = window.open('', '_blank');
            const rows = state.systemLogs.map((l, i) => `
                <tr><td style="padding:8px 10px;font-family:monospace;color:#64748b;font-size:11px">${l.time}</td>
                <td style="padding:8px 10px;font-size:12px">${l.text}</td>
                <td style="padding:8px 10px;text-align:right;font-family:monospace;color:#94a3b8;font-size:11px">${String(i + 1).padStart(4, '0')}</td></tr>
            `).join('');
            w.document.write(`<html><head><title>Sao Kê Nhật Ký Hệ Thống</title>
                <style>body{font-family:'Segoe UI',Arial,sans-serif;padding:40px;color:#1e293b;background:#f8fafc}
                .header{background:linear-gradient(135deg,#1e293b,#0f172a);color:#fff;padding:24px 30px;border-radius:14px;margin-bottom:24px}
                .header h1{margin:0 0 4px;font-size:18px;letter-spacing:1px}.header p{margin:2px 0;font-size:12px;opacity:.85}
                table{width:100%;border-collapse:collapse;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.08)}
                thead th{background:#f1f5f9;text-align:left;padding:10px;font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:#64748b;border-bottom:2px solid #e2e8f0}
                tbody tr{border-bottom:1px solid #f1f5f9}.footer{margin-top:24px;text-align:center;font-size:10px;color:#94a3b8}</style></head><body>
                <div class="header"><h1>📋 SAO KÊ NHẬT KÝ TRỤC LÕI LIÊN THÔNG</h1>
                <p>Trung Tâm Quốc Vụ Số Liên Thông — Phòng Giám Sát Tối Cao</p>
                <p>Ngày xuất: ${new Date().toLocaleString('vi-VN')} • Tổng bản ghi: ${state.systemLogs.length}</p></div>
                <table><thead><tr><th>Thời Gian</th><th>Nội Dung Sự Kiện</th><th style="text-align:right">STT</th></tr></thead>
                <tbody>${rows}</tbody></table>
                <p class="footer">Biểu mẫu sao kê nhật ký mô phỏng phục vụ giám sát hệ thống nhập vai.</p>
            </body></html>`);
            w.document.close(); w.print();
            Toast.success('Đã xuất sao kê nhật ký hệ thống.');
        }

        function selectFile(id) { activeFileId = id; document.getElementById('officer-desk-empty').classList.add('hidden'); document.getElementById('officer-desk-active').classList.remove('hidden'); renderOfficerDesk(); }

        /* VÁ LỖI v14.0: HIỂN THỊ CÔNG DÂN + TÍCH HỢP LUÂN CHUYỂN/TRÌNH KÝ TRONG PHÒNG THẨM ĐỊNH */
        function renderOfficerDesk() {
            let app = state.applications[activeFileId] || state.archivedApplications[activeFileId]; if(!app) return;
            const desk = document.getElementById('officer-desk-active');

            let citizenInfoHtml = `<div class="bg-amber-950/20 border border-amber-900/40 p-3 rounded-xl"><p class="text-amber-500 text-[10px] font-bold"><i class="fa-solid fa-triangle-exclamation"></i> Chưa có dữ liệu định danh cho @${app.sender}. Vui lòng số hóa cư dân trước khi thụ lý.</p></div>`;
            if (registry[app.sender]) {
                let c = registry[app.sender];
                let v = violations[app.sender] || [];
                const licenseNames = (c.licenses || []).map(l => typeof l === 'object' ? l.licenseName : l);
                const avatarThumb = c.avatarUrl
                    ? `<img src="${c.avatarUrl}" onerror="this.style.display='none'" class="w-14 h-14 rounded-xl object-cover border-2 border-amber-500/40 shadow-lg">`
                    : `<div class="w-14 h-14 rounded-xl bg-gray-900 border-2 border-amber-500/20 flex items-center justify-center"><i class="fa-solid fa-user text-gray-600 text-xl"></i></div>`;
                citizenInfoHtml = `
                    <div class="bg-gradient-to-br from-black/60 to-amber-950/10 border border-amber-900/30 p-3 rounded-xl text-[11px] space-y-1.5 text-gray-300 font-medium shadow-inner">
                        <div class="flex items-center gap-3 border-b border-amber-900/20 pb-2 mb-1">
                            ${avatarThumb}
                            <div class="flex-1">
                                <p class="text-sm font-black text-amber-400">${c.name}</p>
                                <p class="text-[10px] text-gray-500 font-mono">@${app.sender} • Số ĐD: ${citizenIdNumber(app.sender)}</p>
                                <p class="text-[10px] text-gray-400">Sinh: ${c.dob} • ${c.gender} • ${c.pob}</p>
                            </div>
                        </div>
                        <p>Nghề nghiệp: <b class="text-white">${c.job}</b></p>
                        <p>Văn bằng (${licenseNames.length}): <span class="text-sky-400 font-bold">${licenseNames.join(' • ') || 'Chưa cấp phôi'}</span></p>
                        <p class="flex justify-between font-bold"><span>Lý lịch: <b class="text-emerald-400">${c.status}</b></span><span>Vi phạm: <b class="text-red-500">${v.length}</b></span></p>
                        ${v.length ? `<div class="pt-1 border-t border-gray-900 space-y-0.5 max-h-[80px] overflow-y-auto">${v.map(vi => `<p class="text-[9px] text-red-400">• ${vi.id}: ${vi.type} — <b class="text-yellow-500">${vi.fine}</b> (${vi.status})</p>`).join('')}</div>` : ''}
                        <button onclick="quickLookup('${app.sender}')" class="w-full mt-1 bg-amber-900/30 hover:bg-amber-900/50 text-amber-300 text-[9px] font-black py-1.5 rounded-lg uppercase"><i class="fa-solid fa-id-card"></i> Xem Hồ Sơ Định Danh Đầy Đủ</button>
                    </div>
                `;
            }

            let chatHtml = app.logs.map(l => `<div class="bg-gray-950 p-2 rounded border border-gray-900 text-[11px]"><p class="text-[9px] text-gray-500 font-bold">${l.sender} • ${l.time}</p><p class="text-white mt-0.5">${l.msg}</p></div>`).join('');

            let actionsHtml = '';
            const isArchived = !state.applications[activeFileId];
            const isLead = activeUser && (activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN');
            const isInspector = activeUser && (activeUser.role === 'THANH TRA' || activeUser.role === 'ADMIN');
            const inComplaint = app.escalationTier && !app.complaintStatus?.includes('BÁC') && app.complaintStatus !== 'ĐÃ CHẤP NHẬN — XEM XÉT LẠI';

            if (!isArchived) {
                if (app.status === 'Đang Chờ Tiếp Nhận' || app.status.includes('Trả Lại Từ Kho')) {
                    actionsHtml = `
                        <div class="bg-sky-950/20 border border-sky-900/40 rounded-xl p-3 space-y-1.5">
                            <p class="text-[9px] font-black text-sky-400 uppercase tracking-wider mb-1"><i class="fa-solid fa-clipboard-check"></i> Xác Nhận Rà Soát Trước Khi Tiếp Nhận</p>
                            <label class="flex items-center gap-2 text-[10px] text-gray-300 font-medium cursor-pointer"><input type="checkbox" class="claim-check" onchange="checkClaimReadiness()"> Đã đối chiếu thông tin công dân với cơ sở dữ liệu định danh</label>
                            <label class="flex items-center gap-2 text-[10px] text-gray-300 font-medium cursor-pointer"><input type="checkbox" class="claim-check" onchange="checkClaimReadiness()"> Nội dung yêu cầu rõ ràng, đầy đủ, không mơ hồ</label>
                            <label class="flex items-center gap-2 text-[10px] text-gray-300 font-medium cursor-pointer"><input type="checkbox" class="claim-check" onchange="checkClaimReadiness()"> Không phát hiện dấu hiệu trùng lặp / mạo danh hồ sơ</label>
                        </div>
                        <button id="btn-claim" disabled onclick="sendAction('${app.id}', 'claim_packet')" class="w-full bg-gray-800 text-gray-500 font-black py-2.5 rounded-xl text-xs uppercase shadow-md tracking-wider cursor-not-allowed transition-all">✓ Ký Nhận Thụ Lý Hồ Sơ</button>
                    `;
                } else if (inComplaint) {
                    const canResolve = (app.escalationTier === 1 && isLead) || (app.escalationTier === 2 && isInspector);
                    actionsHtml = `
                        <div class="bg-red-950/30 border border-red-800 rounded-xl p-2 text-[10px] text-red-300 font-bold text-center">⚠️ Hồ sơ đang trong quy trình khiếu nại Cấp ${app.escalationTier}</div>
                        ${canResolve ? `
                        <div class="grid grid-cols-2 gap-2">
                            <button onclick="sendAction('${app.id}', 'resolve_complaint', '', '', '', 'CHAP_NHAN')" class="bg-emerald-600 text-white font-black py-1.5 rounded-xl text-[10px] uppercase">Chấp Nhận KN</button>
                            <button onclick="sendAction('${app.id}', 'resolve_complaint', '', '', '', 'BAC_BO')" class="bg-red-600 text-white font-black py-1.5 rounded-xl text-[10px] uppercase">Bác Khiếu Nại</button>
                        </div>` : `<p class="text-[9px] text-gray-500 text-center italic">${app.escalationTier === 1 ? 'Chờ Lãnh Đạo cơ quan xử lý' : 'Chờ Thanh Tra xử lý'}</p>`}
                    `;
                } else {
                    actionsHtml = `
                        <div class="grid grid-cols-2 gap-2">
                            ${isLead ? `
                                <button onclick="sendAction('${app.id}', 'status', 'Đã Phê Duyệt', 'stamp-approved')" class="bg-emerald-600 text-white font-black py-1.5 rounded-xl text-[10px] uppercase shadow">Phê Duyệt & Ký</button>
                                <button onclick="sendAction('${app.id}', 'status', 'Bị Bác Bỏ', 'stamp-rejected')" class="bg-red-600 text-white font-black py-1.5 rounded-xl text-[10px] uppercase shadow">Bác Bỏ</button>
                            ` : `
                                <button onclick="sendAction('${app.id}', 'status', 'Trình Duyệt Sắc Lệnh', 'stamp-leader')" class="bg-amber-600 text-black font-black py-1.5 col-span-2 rounded-xl text-[10px] uppercase shadow"><i class="fa-solid fa-file-signature"></i> Trình Ký Lãnh Đạo</button>
                            `}
                        </div>
                        ${isLead ? `<button onclick="sendAction('${app.id}', 'archive')" class="w-full bg-purple-600 text-white font-black py-1.5 rounded-xl text-[10px] uppercase mt-1">Đóng Hồ Sơ → Lưu Kho</button>` : ''}
                        <div class="bg-amber-950/20 border border-amber-900/40 rounded-xl p-2.5 space-y-2 mt-1">
                            <p class="text-[9px] font-black text-amber-400 uppercase"><i class="fa-solid fa-shuffle"></i> Luân Chuyển Liên Ngành (Tích Hợp)</p>
                            <div class="flex gap-1.5">
                                <select id="desk-transfer-agency" class="flex-1 bg-gray-950 border border-gray-800 p-1.5 rounded-lg text-white text-[10px] font-bold focus:outline-none">
                                    <option value="CHÍNH PHỦ">VĂN PHÒNG CHÍNH PHỦ</option><option value="CÔNG AN">BỘ CÔNG AN</option><option value="QUÂN ĐỘI">BỘ QUÂN SỰ</option><option value="TOÀ ÁN">TÒA ÁN</option><option value="THANH TRA">THANH TRA</option><option value="Y TẾ">BỘ Y TẾ</option><option value="GIÁO DỤC">BỘ GIÁO DỤC</option><option value="TÀI CHÍNH">BỘ TÀI CHÍNH</option><option value="UBND">UBND</option>
                                </select>
                                <button onclick="forwardFromDesk('${app.id}')" class="bg-amber-500 text-black font-black px-3 py-1.5 rounded-lg text-[9px] uppercase whitespace-nowrap">Ký Chuyển</button>
                            </div>
                        </div>
                    `;
                }
            } else {
                actionsHtml = `<div class="text-center text-[10px] text-purple-400 font-bold uppercase bg-purple-950/20 p-2 rounded-xl border border-purple-900/40">🔒 Hồ sơ đã niêm phong lưu kho</div>
                    ${isLead || isInspector ? `<button onclick="requestArchiveReturn('${app.id}')" class="w-full bg-amber-700 text-white font-black py-1.5 rounded-xl text-[10px] uppercase mt-1">Yêu Cầu Trả Hồ Sơ Từ Kho</button>` : ''}
                    ${activeUser && activeUser.role === 'ADMIN' ? `<div class="grid grid-cols-2 gap-2 mt-1"><button onclick="returnArchive('${app.id}')" class="bg-sky-700 text-white font-black py-1.5 rounded-xl text-[10px] uppercase">Trả Hồ Sơ</button><button onclick="deleteArchive('${app.id}')" class="bg-red-700 text-white font-black py-1.5 rounded-xl text-[10px] uppercase">Hủy/Xóa</button></div>` : ''}`;
            }

            desk.innerHTML = `
                <div class="flex-1 overflow-y-auto space-y-3 max-h-[400px] pr-1">
                    <div class="bg-gray-950 p-2.5 rounded-xl border border-gray-900 text-[11px] relative shadow-inner">
                        <div class="absolute top-2 right-2 stamp-box ${app.stamp}">${app.status}</div>
                        <p class="font-black text-amber-500 font-mono">MÃ: ${app.id} • ${app.docType} • ${app.agency}</p>
                        <p class="text-gray-400 italic mt-2 bg-black/40 p-2 rounded border border-gray-900 font-medium">"${app.content}"</p>
                        ${app.handler && app.handler !== 'Chưa phân phối' ? `<p class="text-[9px] text-gray-500 mt-1">Cán bộ thụ lý: <b class="text-emerald-400">${app.handler}</b></p>` : ''}
                    </div>
                    <div class="bg-gray-950 p-3 rounded-xl border border-gray-900">${renderStageTracker(app)}</div>
                    <p class="text-[9px] font-black text-sky-400 uppercase tracking-wider flex items-center gap-1"><i class="fa-solid fa-id-card"></i> Hồ Sơ Định Danh Công Dân:</p>
                    ${citizenInfoHtml}
                    <div class="space-y-2" id="officer-chat-flow">${chatHtml}</div>
                </div>
                <div class="pt-2 border-t border-gray-800 space-y-2">
                    ${actionsHtml}
                    <div class="flex gap-2">
                        <input type="text" id="officer-chat-msg" placeholder="Chỉ thị gửi công dân..." class="flex-1 bg-gray-950 border border-gray-800 p-2 text-xs text-white rounded-xl focus:outline-none">
                        <button onclick="officerChat()" class="bg-emerald-600 font-black text-white px-4 text-xs rounded-xl uppercase">Gửi</button>
                    </div>
                </div>
            `;
            setTimeout(() => { const el = document.getElementById('officer-chat-flow'); if (el) el.scrollTop = el.scrollHeight; }, 50);
        }
        async function forwardFromDesk(id) {
            const targetAgency = document.getElementById('desk-transfer-agency').value;
            const data = await apiPost('/api/applications/action', { id, action: 'forward', targetAgency });
            if (data) { soundStamp(); Toast.success(`Đã luân chuyển hồ sơ sang [${targetAgency}].`); }
        }

        // TÍNH NĂNG MỚI v10.0: bật nút Ký Nhận khi cán bộ đã tích đủ 3 mục rà soát
        function checkClaimReadiness() {
            const checks = document.querySelectorAll('.claim-check');
            const btn = document.getElementById('btn-claim');
            if (!btn) return;
            const allChecked = Array.from(checks).every(c => c.checked);
            btn.disabled = !allChecked;
            if (allChecked) { btn.classList.remove('bg-gray-800', 'text-gray-500', 'cursor-not-allowed'); btn.classList.add('bg-gradient-to-r', 'from-sky-500', 'to-blue-600', 'text-white'); }
            else { btn.classList.add('bg-gray-800', 'text-gray-500', 'cursor-not-allowed'); btn.classList.remove('bg-gradient-to-r', 'from-sky-500', 'to-blue-600', 'text-white'); }
        }

        async function officerChat() {
            const msg = document.getElementById('officer-chat-msg').value.trim(); if (!msg) return;
            const data = await apiPost('/api/applications/action', { id: activeFileId, action: 'chat', msg, officerName: `${activeUser.displayName} (${activeUser.agency})` }, { skipSync: true });
            if (data) document.getElementById('officer-chat-msg').value = '';
        }

        async function sendAction(id, action, status = '', stamp = '', targetAgency = '', decision = '') {
            const payload = { id, action, status, stamp, targetAgency };
            if (decision) payload.decision = decision;
            const data = await apiPost('/api/applications/action', payload);
            if (data) {
                if (action === 'status' || action === 'claim_packet' || action === 'archive' || action === 'forward' || action === 'resolve_complaint') soundStamp();
                const labels = { claim_packet: 'Đã ký nhận thụ lý hồ sơ!', archive: 'Đã niêm phong vào kho.', forward: 'Đã luân chuyển hồ sơ.', resolve_complaint: 'Đã xử lý khiếu nại.', status: `Trạng thái: ${status}` };
                if (labels[action]) Toast.success(labels[action]);
            }
        }

        async function publishDocument() {
            const type = document.getElementById('pub-type').value; const title = document.getElementById('pub-title').value.trim(); const content = document.getElementById('pub-content').value.trim(); if(!title || !content) { Toast.warning('Vui lòng nhập đầy đủ tiêu đề và nội dung.'); return; }
            const data = await apiPost('/api/national/publish', { type, title, content });
            if (data) {
                document.getElementById('pub-title').value = ''; document.getElementById('pub-content').value = '';
                if (type === 'TRUY NÃ' && typeof SFX !== 'undefined') SFX.warrantAlarm(); else soundSuccess();
                Toast.success(type === 'TRUY NÃ' ? 'Đã chính thức ban hành lệnh truy nã toàn quốc!' : 'Đã ban hành ấn bản thành công!');
            }
        }

        async function updateTicker() {
            const msg = document.getElementById('pub-ticker').value.trim(); if(!msg) return;
            const data = await apiPost('/api/national/ticker', { message: msg });
            if (data) { document.getElementById('pub-ticker').value = ''; soundSuccess(); Toast.success('Đã cập nhật bảng tin chạy quốc gia.'); }
        }

        async function deleteNews(id) { const data = await apiPost('/api/national/delete-announcement', { id }); if (data) Toast.info('Đã gỡ bỏ ấn bản.'); }
        async function deleteWanted(id) { const data = await apiPost('/api/national/delete-wanted', { id }); if (data) Toast.info('Đã gỡ lệnh truy nã.'); }
        /* VÁ LỖI v6.0: hàm này được gọi từ nút Phê Duyệt / Kỷ Luật Nhắc Nhở trong danh sách báo cáo ca trực nhưng trước đây chưa được định nghĩa, gây lỗi ReferenceError im lặng trên console. */
        async function actionShiftReport(id, status) {
            const feedback = status === 'ĐÃ PHÊ DUYỆT' ? 'Ghi nhận, tiếp tục phát huy trong ca trực tới.' : 'Yêu cầu rút kinh nghiệm và tuân thủ đúng quy trình kịch bản.';
            const data = await apiPost('/api/officer/report-action', { id, status, feedback });
            if (data) { soundSuccess(); Toast.success('Đã cập nhật đánh giá báo cáo ca trực.'); }
        }
        async function setSecurity(level) { const data = await apiPost('/api/national/security', { level }); if (data) { if (typeof SFX !== 'undefined') SFX.warrantAlarm(); Toast.success(`Mức an ninh quốc gia đã chuyển sang: ${level}`); } }
        async function provisionAccount(e) {
            e.preventDefault();
            const username = document.getElementById('p-user').value.trim(); const password = document.getElementById('p-pass').value; const displayName = document.getElementById('p-name').value.trim(); const role = document.getElementById('p-role').value; const agency = document.getElementById('p-agency').value;
            if (!username || !password || !displayName) { Toast.warning('Vui lòng nhập đầy đủ tài khoản, mật khẩu và họ tên.'); return; }
            const data = await apiPost('/api/officer/save', { username, password, displayName, role, agency });
            if (data) { resetProvisionForm(); soundSuccess(); Toast.success(`Đã cấp/cập nhật chứng thư cho @${username} thành công!`); }
        }

        function openLogin() { document.getElementById('login-modal').classList.remove('hidden'); }
        function closeLogin() { document.getElementById('login-modal').classList.add('hidden'); }
        function login() { const u = document.getElementById('log-user').value; const p = document.getElementById('log-pass').value; if (state.authorizedPersonnel[u] && state.authorizedPersonnel[u].password === p) { activeUser = state.authorizedPersonnel[u]; localStorage.setItem('sessionUser', JSON.stringify({ username: u, password: p })); closeLogin(); if (typeof SFX !== 'undefined') SFX.loginFanfare(); else soundSuccess(); applyUserRoleLayout(); socket.emit('identify', { username: u }); Toast.success(`Chào mừng trở lại, ${activeUser.displayName}!`); } else { if (typeof SFX !== 'undefined') SFX.errorBuzz(); Toast.error("Sai tài khoản hoặc mật khẩu, vui lòng kiểm tra lại chứng thư."); } }
        function applyUserRoleLayout() { if(!activeUser) return; document.getElementById('btn-tab-officer').classList.remove('hidden'); if(activeUser.role === 'ADMIN') document.getElementById('btn-tab-admin').classList.remove('hidden'); if(activeUser.role === 'LÃNH ĐẠO' || activeUser.role === 'ADMIN' || activeUser.role === 'THANH TRA' || activeUser.agency === 'CHÍNH PHỦ') { document.getElementById('leader-publish-zone').classList.remove('hidden'); } else { document.getElementById('leader-publish-zone').classList.add('hidden'); } renderAuth(); renderAll(); let savedTab = sessionStorage.getItem('activeTab'); tab(savedTab || 'tab-officer'); }
        function logout() { socket.emit('logout'); activeUser = null; activeFileId = null; localStorage.removeItem('sessionUser'); document.getElementById('btn-tab-officer').classList.add('hidden'); document.getElementById('btn-tab-admin').classList.add('hidden'); renderAuth(); tab('tab-news'); Toast.info('Đã đăng xuất khỏi phiên trực ban.'); }
        function renderAuth() { const p = document.getElementById('auth-panel'); if(!activeUser) { p.innerHTML = `<button onclick="openLogin()" class="bg-amber-500 text-black px-4 py-2 rounded-xl text-[11px] uppercase font-black">Đăng nhập nghiệp vụ</button>`; } else { p.innerHTML = `<div class="bg-gray-950 border border-gray-800 p-1.5 text-xs rounded-xl flex items-center gap-2 shadow-inner"><b class="text-white">${activeUser.displayName}</b><button onclick="logout()" class="text-red-400 ml-2"><i class="fa-solid fa-power-off"></i></button></div>`; } }
        
        startClock();
        updateDocTypeOptions();
        bankRestoreSession();
    </script>
</body>
</html>
