                        analytics.innerHTML += `
                            <div class="bg-gray-950/80 p-3.5 rounded-xl border border-gray-800 text-xs space-y-2">
                                <div class="flex justify-between font-black text-white border-b border-gray-800 pb-1.5"><span>${u.displayName}</span><span class="text-purple-400 text-[10px] uppercase bg-purple-950 px-1.5 rounded border border-purple-800">${u.role}</span></div>
                                <div class="text-[11px] text-gray-400 font-mono flex justify-between"><span>Đơn vị: <b class="text-sky-400">${u.agency}</b></span> <span>Mật mã lõi: <b class="text-amber-400">${u.password}</b></span></div>
                                <div class="flex gap-2 pt-1 border-t border-gray-800/60"><button onclick="editOfficer('${u.username}')" class="flex-1 bg-sky-600 text-white font-bold py-1 rounded text-[10px] uppercase">Sửa đổi</button><button onclick="deleteOfficer('${u.username}')" class="bg-red-600 text-white font-bold px-2 py-1 rounded text-[10px] uppercase">Tước Quyền</button></div>
                            </div>
                        `;
                    }
                });
            }
