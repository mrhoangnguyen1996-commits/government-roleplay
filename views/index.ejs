        async function bankDepositRequest() {
            const amount = document.getElementById('bank-amt').value;
            const method = document.getElementById('bank-deposit-method').value;
            const reference = document.getElementById('bank-deposit-ref').value.trim();
            const note = document.getElementById('bank-deposit-note').value.trim();
            if (!reference) { Toast.warning('Vui lòng nhập mã giao dịch ngân hàng để đối soát.'); return; }
            const data = await apiPost('/api/bank/deposit-request', { accountNumber: bankSession.accountNumber, pin: bankSession.pin, amount, method, reference, note });
            if (data) { soundSuccess(); Toast.success(`Đã gửi yêu cầu nạp tiền [${data.id}], chờ Ngân Hàng phê duyệt.`); document.getElementById('bank-action-box').classList.add('hidden'); refreshBankState(); loadDepositStatus(); }
        }
        async function loadDepositStatus() {
            if (!bankSession) return;
            const data = await apiPost('/api/bank/deposit-status', { accountNumber: bankSession.accountNumber, pin: bankSession.pin }, { silent: true });
            const box = document.getElementById('bank-deposit-status-list');
            if (!box) return;
            if (!data || !data.requests.length) { box.innerHTML = `<p class="text-center text-gray-600 text-[11px] py-3">Chưa có yêu cầu nạp tiền nào.</p>`; return; }
            box.innerHTML = data.requests.map(r => `
                <div class="bg-gray-950 border border-gray-800 p-2.5 rounded-xl text-[11px] flex justify-between">
                    <div><p class="font-black text-white">${r.id} — ${fmtVND(r.amount)}</p><p class="text-gray-500 text-[9px]">${r.method} • Mã GD: ${r.reference} • ${r.time}</p></div>
                    <b class="${r.status === 'ĐÃ DUYỆT' ? 'text-emerald-400' : r.status === 'TỪ CHỐI' ? 'text-red-400' : 'text-amber-400'}">${r.status}</b>
                </div>
            `).join('');
        }
        async function bankWithdraw() {
            const amount = document.getElementById('bank-amt').value;
            const data = await apiPost('/api/bank/withdraw', { accountNumber: bankSession.accountNumber, pin: bankSession.pin, amount });
            if (data) { soundStamp(); Toast.success(`Rút tiền thành công! Biên lai: ${data.billId}`); document.getElementById('bank-action-box').classList.add('hidden'); refreshBankState(); }
        }
        async function bankTransfer() {
            const toAccountNumber = document.getElementById('bank-to').value.trim();
            const amount = document.getElementById('bank-amt').value;
            const note = document.getElementById('bank-note').value.trim();
            const data = await apiPost('/api/bank/transfer', { accountNumber: bankSession.accountNumber, pin: bankSession.pin, toAccountNumber, amount, note });
            if (data) { soundStamp(); Toast.success(`Chuyển khoản thành công! Biên lai: ${data.billId}`); document.getElementById('bank-action-box').classList.add('hidden'); refreshBankState(); }
        }
        async function bankPayFine() {
            const violationId = document.getElementById('bank-vp').value.trim();
            const data = await apiPost('/api/bank/pay-fine', { accountNumber: bankSession.accountNumber, pin: bankSession.pin, violationId });
            if (data) { soundStamp(); Toast.success(`Đã nộp phạt thành công! Biên lai: ${data.billId}`); document.getElementById('bank-action-box').classList.add('hidden'); refreshBankState(); }
        }
        async function bankSavings(action) {
            const amount = document.getElementById('bank-amt').value;
            const data = await apiPost('/api/bank/savings', { accountNumber: bankSession.accountNumber, pin: bankSession.pin, amount, action });
            if (data) { soundSuccess(); Toast.success(action === 'gui' ? 'Đã gửi vào sổ tiết kiệm!' : 'Đã rút khỏi sổ tiết kiệm!'); document.getElementById('bank-action-box').classList.add('hidden'); refreshBankState(); }
        }
        async function bankLoanRequest() {
            const amount = document.getElementById('bank-amt').value;
            const reason = document.getElementById('bank-reason').value.trim();
            const data = await apiPost('/api/bank/loan/request', { accountNumber: bankSession.accountNumber, pin: bankSession.pin, amount, reason });
            if (data) { soundSuccess(); Toast.success(`Đã gửi yêu cầu vay vốn [${data.id}], chờ Ngân Hàng xét duyệt.`); document.getElementById('bank-action-box').classList.add('hidden'); refreshBankState(); }
        }
