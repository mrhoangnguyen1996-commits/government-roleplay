        function citizenIdNumber(username) {
            let hash = 0;
            for (let i = 0; i < username.length; i++) { hash = (hash * 31 + username.charCodeAt(i)) >>> 0; }
            return '068' + String(hash % 1000000000).padStart(9, '0');
        }

        // =====================================================================
        // MODULE NGÂN HÀNG SỐ v11.0 — TOÀN BỘ LOGIC PHÍA CÔNG DÂN + NHÂN VIÊN
        // Phiên đăng nhập ngân hàng lưu RIÊNG BIỆT với phiên đăng nhập cán bộ
        // (không dùng chung activeUser), để đúng bản chất "công dân" khác "cán bộ".
        // =====================================================================
        // =====================================================================
        // TÍNH NĂNG MỚI v13.0: DẢI HOẠT ĐỘNG TRỰC TIẾP (LIVE ACTIVITY FEED)
        // Hiển thị luân phiên các sự kiện công khai gần nhất (hồ sơ mới, SOS,
        // cán bộ vào trực...) để trang có cảm giác sống động, nhiều người
        // đang cùng tham gia — không lộ thông tin nhạy cảm.
        // =====================================================================
        let liveActivityQueue = [];
        let liveActivityIndex = 0;
        function pushLiveActivity(text) {
            liveActivityQueue.unshift({ text, time: new Date().toLocaleTimeString('vi-VN') });
            if (liveActivityQueue.length > 20) liveActivityQueue.pop();
            renderLiveActivityTicker();
        }
        function renderLiveActivityTicker() {
            const el = document.getElementById('live-activity-feed');
            if (!el || !liveActivityQueue.length) return;
            const item = liveActivityQueue[0];
            el.innerText = `[${item.time}] ${item.text}`;
        }
        setInterval(() => {
            if (!liveActivityQueue.length) return;
            liveActivityIndex = (liveActivityIndex + 1) % liveActivityQueue.length;
            const el = document.getElementById('live-activity-feed');
            if (el) { const item = liveActivityQueue[liveActivityIndex]; el.style.opacity = '0'; setTimeout(() => { el.innerText = `[${item.time}] ${item.text}`; el.style.opacity = '1'; }, 200); }
        }, 6000);

        let bankSession = null; // { accountNumber, pin }
        let bankData = null;    // { account, transactions, loans }
        function fmtVND(n) { return (n || 0).toLocaleString('vi-VN') + ' VND'; }

        function bankRestoreSession() {
            const saved = localStorage.getItem('bankSession');
            if (saved) { try { bankSession = JSON.parse(saved); refreshBankState(); } catch (e) { localStorage.removeItem('bankSession'); } }
        }

        async function bankLogin() {
            const accountNumber = document.getElementById('bank-login-accnum').value.trim();
            const pin = document.getElementById('bank-login-pin').value.trim();
            if (!accountNumber || !pin) { Toast.warning('Vui lòng nhập đầy đủ số tài khoản và mã PIN.'); return; }
            const data = await apiPost('/api/bank/login', { accountNumber, pin }, { silent: true });
            if (data) {
                bankSession = { accountNumber, pin };
                localStorage.setItem('bankSession', JSON.stringify(bankSession));
                bankData = data; renderBankDashboard();
                document.getElementById('bank-request-box').classList.add('hidden');
                soundSuccess(); Toast.success('Đăng nhập Ngân Hàng Số thành công!');
            }
        }

        // TÍNH NĂNG MỚI v12.0: CÔNG DÂN TỰ GỬI BIỂU MẪU XIN CẤP TÀI KHOẢN
        async function submitBankAccountRequest() {
            const username = document.getElementById('bank-req-user').value.trim();
            const fullName = document.getElementById('bank-req-name').value.trim();
            const purpose = document.getElementById('bank-req-purpose').value.trim();
            const pin = document.getElementById('bank-req-pin').value.trim();
            if (!username || !fullName || !pin) { Toast.warning('Vui lòng nhập đầy đủ tài khoản, họ tên và mã PIN.'); return; }
            const data = await apiPost('/api/bank/request-account', { username, fullName, purpose, pin });
            if (data) {
                document.getElementById('bank-req-user').value = ''; document.getElementById('bank-req-name').value = ''; document.getElementById('bank-req-purpose').value = ''; document.getElementById('bank-req-pin').value = '';
                soundSuccess(); Toast.success(`Đã gửi yêu cầu mở tài khoản [${data.id}], vui lòng chờ Ngân Hàng xét duyệt và trả kết quả.`);
            }
        }
        async function checkBankRequestStatus() {
            const username = document.getElementById('bank-req-check-user').value.trim(); if (!username) return;
            const data = await apiPost('/api/bank/request-status', { username }, { silent: true });
            const box = document.getElementById('bank-req-status-result');
            if (!data || !data.requests.length) { box.innerHTML = `<p class="text-[10px] text-gray-600 text-center">Chưa có yêu cầu nào cho tài khoản này.</p>`; return; }
            box.innerHTML = data.requests.map(r => `
                <div class="bg-gray-950 border border-gray-800 p-2 rounded-lg text-[10px] flex justify-between">
                    <span>${r.id} — ${r.time}</span>
                    <b class="${r.status === 'ĐÃ DUYỆT' ? 'text-emerald-400' : r.status === 'TỪ CHỐI' ? 'text-red-400' : 'text-amber-400'}">${r.status}${r.accountNumber ? ` (${r.accountNumber})` : ''}</b>
                </div>
            `).join('');
        }

        function bankLogout() {
            bankSession = null; bankData = null;
            localStorage.removeItem('bankSession');
            document.getElementById('bank-login-box').classList.remove('hidden');
            document.getElementById('bank-dashboard').classList.add('hidden');
            Toast.info('Đã đăng xuất khỏi Ngân Hàng Số.');
        }
        async function refreshBankState() {
            if (!bankSession) return;
            const data = await apiPost('/api/bank/my-state', { accountNumber: bankSession.accountNumber, pin: bankSession.pin }, { silent: true });
            if (data) { bankData = data; renderBankDashboard(); loadDepositStatus(); } else { bankLogout(); }
        }
        function renderBankDashboard() {
            if (!bankData) return;
            document.getElementById('bank-login-box').classList.add('hidden');
            document.getElementById('bank-dashboard').classList.remove('hidden');
            document.getElementById('bank-balance-display').innerText = fmtVND(bankData.account.balance);
            document.getElementById('bank-savings-display').innerText = fmtVND(bankData.account.savings);
            document.getElementById('bank-accnum-display').innerText = bankData.account.accountNumber;
            const txList = document.getElementById('bank-tx-list');
            txList.innerHTML = bankData.transactions.length ? bankData.transactions.map(t => `
                <div class="bg-gray-950 border border-gray-800 p-2.5 rounded-xl flex justify-between items-center text-[11px]">
                    <div><p class="font-black ${t.amount >= 0 ? 'text-emerald-400' : 'text-red-400'}">${t.type}</p><p class="text-gray-500 text-[9px]">${t.time} • ${t.note || t.counterpart}</p></div>
                    <div class="text-right">
                        <b class="${t.amount >= 0 ? 'text-emerald-400' : 'text-red-400'} font-mono">${t.amount >= 0 ? '+' : ''}${fmtVND(t.amount)}</b>
