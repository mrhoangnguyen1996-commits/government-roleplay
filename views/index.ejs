        // ---- BẢNG ĐIỀU HÀNH NHÂN VIÊN / LÃNH ĐẠO NGÂN HÀNG / ADMIN ----
        function isBankStaff() { return activeUser && (activeUser.role === 'ADMIN' || activeUser.agency === 'NGÂN HÀNG'); }
        function isBankLeader() { return activeUser && (activeUser.role === 'ADMIN' || (activeUser.agency === 'NGÂN HÀNG' && activeUser.role === 'LÃNH ĐẠO')); }
        let payrollPreviewData = null;
        async function loadBankStaffPanel() {
            const panel = document.getElementById('bank-staff-panel');
            if (!isBankStaff()) { panel.classList.add('hidden'); return; }
            panel.classList.remove('hidden');
            document.getElementById('bank-payroll-zone').classList.toggle('hidden', !isBankLeader());
            const data = await apiPost('/api/bank/staff-state', {}, { silent: true });
            if (!data) return;
            document.getElementById('bstaff-count').innerText = data.accounts.length;
            document.getElementById('bstaff-total').innerText = fmtVND(data.accounts.reduce((s, a) => s + a.balance, 0));
            document.getElementById('bstaff-treasury').innerText = fmtVND(data.treasuryBalance);
            document.getElementById('bstaff-loans').innerText = data.loans.filter(l => l.status === 'CHỜ DUYỆT').length;
            document.getElementById('bstaff-reqs').innerText = (data.accountRequests || []).filter(r => r.status === 'CHỜ DUYỆT').length;

            const pendingDeposits = (data.depositRequests || []).filter(r => r.status === 'CHỜ DUYỆT');
            document.getElementById('bstaff-deposits-list').innerHTML = pendingDeposits.length ? pendingDeposits.map(r => `
                <div class="bg-gray-950 border border-gray-800 p-3 rounded-xl text-[11px] flex justify-between items-center">
                    <div><p class="font-black text-white">@${r.username} — ${fmtVND(r.amount)}</p><p class="text-gray-500 text-[10px]">${r.method} • Mã GD: <span class="font-mono text-amber-400">${r.reference}</span> • ${r.time}</p></div>
                    <div class="flex gap-1.5"><button onclick="decideDeposit('${r.id}','DUYỆT')" class="bg-emerald-600 text-white font-black px-2.5 py-1 rounded-lg text-[9px] uppercase">Duyệt</button><button onclick="decideDeposit('${r.id}','TỪ CHỐI')" class="bg-red-600 text-white font-black px-2.5 py-1 rounded-lg text-[9px] uppercase">Từ Chối</button></div>
                </div>
            `).join('') : `<p class="text-center text-gray-600 text-[11px] py-4">Không có yêu cầu nạp tiền nào đang chờ.</p>`;

            const pendingPayrolls = (data.payrollBatches || []).filter(b => b.status === 'CHỜ ADMIN PHÊ DUYỆT');
            document.getElementById('payroll-pending-list').innerHTML = pendingPayrolls.length ? pendingPayrolls.map(b => `
                <div class="bg-yellow-950/20 border border-yellow-900/40 p-3 rounded-xl text-[11px]">
                    <div class="flex justify-between items-center"><p class="font-black text-white">${b.id} — Kỳ ${b.period} — Tổng: ${fmtVND(b.totalNet)}</p><span class="text-amber-400 font-black">${b.status}</span></div>
                    <p class="text-gray-500 text-[10px] mt-1">Trình bởi: ${b.submittedBy} • ${b.time}</p>
                    ${activeUser.role === 'ADMIN' ? `<div class="flex gap-2 mt-2"><button onclick="decidePayroll('${b.id}','DUYỆT')" class="bg-emerald-600 text-white font-black px-3 py-1 rounded-lg text-[9px] uppercase">Phê Duyệt Chi Lương</button><button onclick="decidePayroll('${b.id}','TỪ CHỐI')" class="bg-red-600 text-white font-black px-3 py-1 rounded-lg text-[9px] uppercase">Từ Chối</button></div>` : ''}
                </div>
            `).join('') : `<p class="text-center text-gray-600 text-[11px] py-3">Không có bảng lương chờ phê duyệt.</p>`;

            const pendingReqs = (data.accountRequests || []).filter(r => r.status === 'CHỜ DUYỆT');
            document.getElementById('bstaff-requests-list').innerHTML = pendingReqs.length ? pendingReqs.map(r => `
                <div class="bg-gray-950 border border-gray-800 p-3 rounded-xl text-[11px] flex justify-between items-center">
                    <div><p class="font-black text-white">@${r.username} — ${r.fullName}</p><p class="text-gray-500 text-[10px]">${r.purpose || 'Không ghi mục đích'} • ${r.time}</p></div>
                    <div class="flex gap-1.5"><button onclick="decideBankRequest('${r.id}','DUYỆT')" class="bg-emerald-600 text-white font-black px-2.5 py-1 rounded-lg text-[9px] uppercase">Duyệt</button><button onclick="decideBankRequest('${r.id}','TỪ CHỐI')" class="bg-red-600 text-white font-black px-2.5 py-1 rounded-lg text-[9px] uppercase">Từ Chối</button></div>
                </div>
            `).join('') : `<p class="text-center text-gray-600 text-[11px] py-4">Không có yêu cầu mở tài khoản nào đang chờ.</p>`;

            document.getElementById('bstaff-accounts-table').innerHTML = data.accounts.map(a => `
                <tr><td class="p-2 font-mono">${a.accountNumber}</td><td class="p-2 font-bold">@${a.username}</td><td class="p-2 text-emerald-400 font-mono">${fmtVND(a.balance)}</td><td class="p-2 text-amber-400 font-mono">${fmtVND(a.savings)}</td>
                <td class="p-2">${a.frozen ? '<span class="text-red-400 font-black">KHOÁ</span>' : '<span class="text-emerald-400 font-black">HOẠT ĐỘNG</span>'}</td>
                <td class="p-2 text-right"><button onclick="toggleFreeze('${a.username}', ${!a.frozen})" class="bg-gray-800 text-[9px] font-black px-2 py-1 rounded-lg uppercase">${a.frozen ? 'Mở Khoá' : 'Khoá'}</button> <button onclick="adjustBankPrompt('${a.username}')" class="bg-sky-800 text-[9px] font-black px-2 py-1 rounded-lg uppercase">Điều Chỉnh</button></td></tr>
            `).join('') || `<tr><td colspan="6" class="p-4 text-center text-gray-600">Chưa có tài khoản nào.</td></tr>`;

            const pendingLoans = data.loans.filter(l => l.status === 'CHỜ DUYỆT');
            document.getElementById('bstaff-loans-list').innerHTML = pendingLoans.length ? pendingLoans.map(l => `
                <div class="bg-gray-950 border border-gray-800 p-3 rounded-xl text-[11px] flex justify-between items-center">
                    <div><p class="font-black text-white">@${l.username} — ${fmtVND(l.amount)}</p><p class="text-gray-500 text-[10px]">${l.reason} • ${l.time}</p></div>
                    <div class="flex gap-1.5"><button onclick="decideLoan('${l.id}','DUYỆT')" class="bg-emerald-600 text-white font-black px-2.5 py-1 rounded-lg text-[9px] uppercase">Duyệt</button><button onclick="decideLoan('${l.id}','TỪ CHỐI')" class="bg-red-600 text-white font-black px-2.5 py-1 rounded-lg text-[9px] uppercase">Từ Chối</button></div>
                </div>
            `).join('') : `<p class="text-center text-gray-600 text-[11px] py-4">Không có yêu cầu nào đang chờ.</p>`;

            document.getElementById('bstaff-tx-list').innerHTML = data.transactions.slice(0, 60).map(t => `<p class="text-[10px] text-gray-400 border-b border-gray-900 py-1"><span class="font-mono text-gray-600">${t.time}</span> — <b class="${t.amount >= 0 ? 'text-emerald-400' : 'text-red-400'}">${t.type}</b> [${t.accountNumber}] ${t.amount >= 0 ? '+' : ''}${fmtVND(t.amount)}</p>`).join('') || '<p class="text-gray-600 text-center py-4">Chưa có giao dịch.</p>';
        }
        async function issueBankAccount() {
            const username = document.getElementById('bstaff-issue-user').value.trim();
            const pin = document.getElementById('bstaff-issue-pin').value.trim();
            const data = await apiPost('/api/bank/issue-account', { username, pin });
            if (data) { document.getElementById('bstaff-issue-user').value = ''; document.getElementById('bstaff-issue-pin').value = ''; soundSuccess(); Toast.success(`Đã cấp tài khoản ngân hàng [${data.accountNumber}] cho @${username}!`); loadBankStaffPanel(); }
        }
        async function toggleFreeze(username, freeze) {
            const data = await apiPost('/api/bank/adjust', { username, action: freeze ? 'freeze' : 'unfreeze' });
            if (data) { Toast.success(freeze ? 'Đã tạm khoá tài khoản.' : 'Đã mở khoá tài khoản.'); loadBankStaffPanel(); }
        }
        async function adjustBankPrompt(username) {
            const amount = prompt('Nhập số tiền điều chỉnh (số âm để trừ, số dương để cộng):');
            if (amount === null || !amount.trim()) return;
            const note = prompt('Lý do điều chỉnh:') || '';
            const data = await apiPost('/api/bank/adjust', { username, action: 'adjust', amount, note });
            if (data) { Toast.success('Đã điều chỉnh số dư tài khoản.'); loadBankStaffPanel(); }
        }
